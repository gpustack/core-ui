{
  "name": "@gpustack/core-ui",
  "version": "1.0.36",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gpustack/core-ui.git"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.less"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js"
    },
    "./charts": {
      "types": "./dist/charts.d.ts",
      "import": "./dist/charts.es.js"
    },
    "./markdown": {
      "types": "./dist/markdown.d.ts",
      "import": "./dist/markdown.es.js"
    },
    "./terminal": {
      "types": "./dist/terminal.d.ts",
      "import": "./dist/terminal.es.js"
    },
    "./yaml-editor": {
      "types": "./dist/yaml-editor.d.ts",
      "import": "./dist/yaml-editor.es.js"
    },
    "./excel": {
      "types": "./dist/excel.d.ts",
      "import": "./dist/excel.es.js"
    },
    "./file-readers": {
      "types": "./dist/file-readers.d.ts",
      "import": "./dist/file-readers.es.js"
    },
    "./utils": {
      "types": "./dist/lib/utils/index.d.ts",
      "import": "./dist/utils.es.js"
    },
    "./style.css": "./dist/index.css"
  },
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && vite build",
    "build:watch": "vite build --watch",
    "clean": "rimraf dist",
    "dev": "vite",
    "lint": "eslint .",
    "prepare": "husky",
    "prepublishOnly": "pnpm build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.app.json --noEmit"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,less,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@braintree/sanitize-url": "^7.1.1",
    "@orcid/bibtex-parse-js": "^0.0.25",
    "@xterm/addon-fit": "^0.10.0",
