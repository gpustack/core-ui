    "mammoth": "^1.8.0",
    "marked": "^14.1.0",
    "pdfjs-dist": "^4.7.76",
    "query-string": "^9.0.0",
    "rc-resize-observer": "^1.4.3",
    "re-resizable": "^6.10.1",
    "react-hotkeys-hook": "^4.5.0",
    "react-intersection-observer": "^9.16.0",
    "react-markdown": "^9.0.3",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "simplebar-react": "^3.2.6",
    "tinycolor2": "^1.6.0",
